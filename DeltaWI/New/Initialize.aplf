         :Case 'Hide'
             object._visibleв†ђv0
             'Hide'##.Event object ##.Application,aarg вЌќ Run the onHide event handler with arguments
             object ##.в€†WSet('Active' 1)('Visible' 0)
         :Case 'Show'
